# Telegram
TELEGRAM_BOT_TOKEN="cole_o_token_aqui"
TELEGRAM_CHAT_ID="cole_o_chat_id_aqui"

# Identificador do servidor (aparece nas mensagens)
SERVER_NAME="$(hostname)"

# Serviços systemd a monitorar (separados por espaço)
SERVICES="nginx redis-server postgresql supervisor"

# Diretório do nginx sites-enabled (sites a verificar via HTTP)
NGINX_SITES_DIR="/etc/nginx/sites-enabled"

# Sites a IGNORAR (server_name) - separados por espaço
# Ex: "default _ localhost"
IGNORE_SITES="default _ localhost"

# Limites de alerta (%)
MEM_THRESHOLD=85
DISK_THRESHOLD=85

# Timeout das requisições HTTP (segundos)
HTTP_TIMEOUT=8

# Re-alertar a cada N minutos se continuar caído (0 = só avisa quando cai/volta)
REALERT_MINUTES=60
