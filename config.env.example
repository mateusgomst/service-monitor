# =============================================================================
# Service Monitor — configuração
# =============================================================================

# ----- Telegram -----
TELEGRAM_BOT_TOKEN="cole_o_token_aqui"
TELEGRAM_CHAT_ID="cole_o_chat_id_aqui"

# Identificador do servidor (aparece nas mensagens)
SERVER_NAME="$(hostname)"


# ----- Serviços systemd -----
# Separados por espaço.
SERVICES="nginx redis-server postgresql supervisor"


# ----- Sites HTTP/HTTPS -----
# Uma URL por linha. Sintaxe:
#   URL
#   URL | codigo_esperado
#   URL | codigo_esperado | substring_que_deve_aparecer_no_body
#
# A URL é chamada DIRETO (sem --resolve 127.0.0.1). Se o site usa DNS local
# apontando pra própria máquina, isso continua funcionando via /etc/hosts.
# Para sites em portas não-padrão, inclua a porta na URL: https://x.com:445
#
# Exemplos:
#   https://toshop.com.br
#   https://monit.sysout.com.br:445 | 200
#   https://api.exemplo.com/health | 200 | "status":"ok"
SITES="
"


# ----- Checagens TCP (só conexão) -----
# host:porta por linha. Útil pra Redis, Postgres, MySQL, etc.
TCP_CHECKS="
"


# ----- Memória -----
MEM_THRESHOLD=85


# ----- Disco -----
# Threshold default (%) aplicado a todos os mounts não listados em DISK_OVERRIDES.
DISK_THRESHOLD=85

# Threshold customizado por mount. Sintaxe: mount|threshold (uma por linha).
# Mounts não listados usam DISK_THRESHOLD.
DISK_OVERRIDES="
"

# Prefixos de mounts a IGNORAR (separados por espaço). Default cobre pseudo-fs.
DISK_IGNORE="/snap /boot/efi /run /dev /sys /proc /run/user"


# ----- HTTP -----
# Timeout (segundos) por requisição HTTP/TCP.
HTTP_TIMEOUT=8

# Validar certificado TLS? "false" mantém comportamento do script antigo (curl -k),
# útil pra certificados self-signed em ambientes internos.
HTTP_VERIFY_TLS=false


# ----- Anti-spam -----
# Quantas falhas consecutivas antes de notificar DOWN. 2 = ignora blip de 1 ciclo.
CONFIRM_FAILURES=2

# Re-alertar a cada N minutos se continuar caído (0 = só avisa quando cai/volta).
REALERT_MINUTES=60
